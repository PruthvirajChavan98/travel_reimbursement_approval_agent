# Frontend env (Vite reads VITE_* vars). Copy to .env.local for local dev.

# Backend API base that the Vite dev proxy forwards /api → (see vite.config.ts).
VITE_API_BASE_URL="http://localhost:8000"

# Set to "1" to use the built-in mock adapter (no backend required); "0" for the real API.
VITE_USE_MOCKS="0"
