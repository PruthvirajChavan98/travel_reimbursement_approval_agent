# Azure AI Foundry — gpt-oss-120b (OpenAI-compatible /openai/v1 endpoint).
# Copy to `.env` and fill in the API key. `.env` is gitignored; never commit secrets.
# Leave AZURE_OPENAI_API_KEY blank to run in deterministic mock mode (no network).

# Note the trailing slash and /openai/v1 path — required by the v1 surface.
AZURE_OPENAI_BASE_URL="YOUR_AZURE_OPENAI_BASE_URL"
AZURE_OPENAI_API_KEY="YOUR_AZURE_OPENAI_API_KEY"
# Foundry routes by deployment name, passed as the `model` argument.
AZURE_OPENAI_DEPLOYMENT="gpt-oss-120b"
# low | medium | high (default high for adjudication).
AZURE_OPENAI_REASONING_EFFORT="high"

# --- LangGraph durable state (Postgres checkpointer) ---
# Unset/blank => in-memory checkpointer fallback (state lost on restart; fine for a cold-clone demo).
# With docker-compose the host is `postgres`; for a local run use localhost.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/checkpointer?sslmode=disable"
LANGGRAPH_STRICT_MSGPACK="true"

# --- Langfuse v2 (self-hosted) observability ---
# Leave the keys blank to disable tracing (clean no-op). With docker-compose the host is http://langfuse:3000.
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="http://localhost:3000"

# --- Frontend connection (CORS) ---
# Comma-separated browser origins allowed to call the API directly (the Vite dev server and the
# nginx-served web container). The Docker `web` service uses a same-origin /api proxy, so this
# mainly matters for `npm run dev`.
CORS_ORIGINS="http://localhost:5173,http://localhost:8080"

# --- Receipt VLM (bill upload: image / scanned-PDF extraction) ---
# Kimi-K2.6 is the vision model. By design it is reached via the SAME /openai/v1 host + key
# as gpt-oss (no Entra) — only the model name differs. Leave VLM_BASE_URL/VLM_API_KEY blank to
# reuse AZURE_OPENAI_BASE_URL / AZURE_OPENAI_API_KEY. (The Foundry /api/projects/ endpoint is
# Entra-only and intentionally NOT used here.)
VLM_MODEL="Kimi-K2.6"
VLM_BASE_URL=""
VLM_API_KEY=""
# Max bill-upload size in MB (kept in sync with nginx client_max_body_size).
MAX_UPLOAD_MB="20"


# --- Cloudflare Tunnel ---
# Token-based tunnel; cloudflared reads TUNNEL_TOKEN natively. With docker-compose NO host ports
# are published, so the tunnel is the only public entrypoint. Add public hostnames in the
# Cloudflare Zero Trust dashboard pointing at HTTP service `web:80`. Leave blank to disable.
TUNNEL_TOKEN="YOUR_CLOUDFLARE_TUNNEL_TOKEN"